<!DOCTYPE html>
<html lang="en">
<head>
{% block head %}
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="color-scheme" content="dark light" />
{% if labels.title %}
<title>{{labels.title}}</title>
{% endif %}
{% block style %}
<style>
{{css}}
</style>
{% endblock style %}
{% endblock head %}
</head>

<body>
{% block body %}
{% if labels.title %}
<h1> {{labels.title}} </h1>
{% endif %}

{{svg}}

{% block vertices %}
{% if config.showVertices %}
<h2> {{labels.vertices}} </h2>
<ol>
{% for vid, vertex in vertices.items() %}
<li id="vertex.{{vertex.id}}">
    {% if vertex.url %}<a href="{{vertex.url}}">{% endif %}
<span class="label">{{vertex.name}}</span>{% if vertex.text %}: {{vertex.text}}{% endif %}
    {% if vertex.url %}</a>{% endif %}
</li>
{% endfor %}
</ol>
{% endif %}
{% endblock vertices %}

{% block edges %}
{% if config.showEdges %}
<h2> {{labels.edges}} </h2>
<ol>
{% for edge in edges %}
<li id="edge.{{edge.id}}">
    {% if edge.url %}<a href="{{edge.url}}">{% endif %}
<span class="label">{{edge.from}} {% if edge.bidir %}={% else %}→{% endif %} {{edge.to}}</span>{% if edge.text %}: {{edge.text}}{% endif %}
    {% if edge.url %}</a>{% endif %}
</li>
{% endfor %}
</ol>
{% endif %}
{% endblock edges %}
{% endblock body %}
</body>
</html>
